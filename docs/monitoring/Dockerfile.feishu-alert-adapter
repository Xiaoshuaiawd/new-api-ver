FROM golang:1.25-alpine AS builder

WORKDIR /workspace

COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -trimpath -ldflags="-s -w" -o /out/feishu-alert-adapter ./cmd/feishu-alert-adapter

FROM alpine:3.22

RUN apk add --no-cache ca-certificates tzdata

ENV TZ=Asia/Shanghai

COPY --from=builder /out/feishu-alert-adapter /usr/local/bin/feishu-alert-adapter

EXPOSE 9098

ENTRYPOINT ["feishu-alert-adapter"]
